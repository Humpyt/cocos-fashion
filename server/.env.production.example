NODE_ENV=production
PORT=4000

# Replace with your production PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/cocos_fashion

# Domain allow-list for production CORS checks.
CORS_ORIGIN=https://cocofashionbrands.com,https://www.cocofashionbrands.com

# Use long random values (at least 32+ chars recommended).
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Cookie settings for HTTPS domain.
COOKIE_DOMAIN=.cocofashionbrands.com
COOKIE_SECURE=true

# Set true when app is behind Nginx reverse proxy.
TRUST_PROXY=true
