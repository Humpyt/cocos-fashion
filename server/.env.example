NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cocos_fashion
# Comma-separated allowed origins for test/production.
# In development, localhost/127.0.0.1 on any port are also allowed automatically.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

JWT_ACCESS_SECRET=change-this-access-secret-to-a-long-random-value
JWT_REFRESH_SECRET=change-this-refresh-secret-to-a-long-random-value
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

COOKIE_DOMAIN=
COOKIE_SECURE=false

ADMIN_EMAIL=admin@cocos.local
ADMIN_PASSWORD=Admin123!@#
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
