NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Comma-separated allowed origins for test/production.
# In development, localhost/127.0.0.1 on any port are also allowed automatically.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

JWT_ACCESS_SECRET=change-this-access-secret-to-a-long-random-value
JWT_REFRESH_SECRET=change-this-refresh-secret-to-a-long-random-value
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

COOKIE_DOMAIN=
COOKIE_SECURE=false
TRUST_PROXY=false

ADMIN_EMAIL=admin@cocos.local
ADMIN_PASSWORD=Admin123!@#
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000
